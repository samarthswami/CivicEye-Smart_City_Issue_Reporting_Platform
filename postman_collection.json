      "name": "Authentication",
      "item": [
        {
          "name": "Citizen Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+1234567890\",\n  \"city\": \"New Delhi\",\n  \"ward\": \"Ward 15\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/citizen/signup",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "citizen", "signup"]
            }
          }
        },
        {
          "name": "Citizen Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"TOKEN\", jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/citizen/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "citizen", "login"]
            }
          }
        },
