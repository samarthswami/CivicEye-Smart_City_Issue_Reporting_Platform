                {
                  "key": "description",
                  "value": "Dangerous pothole causing traffic issues",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "pothole",
                  "type": "text"
                },
                {
                  "key": "severity",
                  "value": "high",
                  "type": "text"
                },
                {
                  "key": "latitude",
                  "value": "28.6139",
                  "type": "text"
                },
                {
                  "key": "longitude",
                  "value": "77.2090",
                  "type": "text"
                },
                {
                  "key": "address",
                  "value": "Main Street, Sector 15",
                  "type": "text"
                },
                {
                  "key": "city",
                  "value": "New Delhi",
                  "type": "text"
                },
                {
